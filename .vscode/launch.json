{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Generate synthetic dataset",
            "type": "debugpy",
            "request": "launch",
            "program": "src/generate_synthetic_mar.py",
            "args": [
                "--input", "/workspace/data/EG2026/sample_volume_for_synthetic_generation/pancreas_metal.mat",
            ],            
            "console": "integratedTerminal",
        },    
        {
            "name": "Initialize point cloud",
            "type": "debugpy",
            "request": "launch",
            "program": "src/initialize_pcd.py",
            "args": [
                "--data", "/workspace/data/EG2026/real_walnut",
            ],            
            "console": "integratedTerminal",
        },    
        {
            "name": "Train start!",
            "type": "debugpy",
            "request": "launch",
            "program": "src/train.py",
            "args": [
                "--config", "/workspace/src/config/default.yaml",
            ],            
            "console": "integratedTerminal",
            "env": {
                    "CUDA_LAUNCH_BLOCKING": "1"
                }            
        },     
    ]
}